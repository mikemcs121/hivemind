{
  "name": "hivemind",
  "version": "0.1.0",
  "description": "Run a swarm of Claude threads in tiled panes, organized into project boards",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w @homebridge/node-pty-prebuilt-multiarch",
    "fetch-model": "node scripts/fetch-model.mjs",
    "postinstall": "node scripts/fetch-model.mjs --soft",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@huggingface/transformers": "^3.8.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^29.4.6",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.mikem.hivemind",
    "productName": "Hivemind",
    "npmRebuild": false,
    "beforeBuild": "./scripts/before-build.js",
    "files": [
      "**/*"
    ],
    "asarUnpack": [
      "models/**",
      "node_modules/@huggingface/transformers/dist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
